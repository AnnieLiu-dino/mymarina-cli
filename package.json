{
  "name": "@mymarina/cli",
  "version": "0.1.1",
  "description": "Frontend scaffolding CLI",
  "main": "lib/index.js",
  "bin": {
    "mymarina": "bin/index.js"
  },
  "scripts": {
    "dev": "node bin/index.js",
    "test": "node --test",
    "check:version": "node bin/index.js --version",
    "format": "prettier --write \"**/*.{js,json,md}\""
  },
  "type": "commonjs",
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "bin",
    "lib"
  ],
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "cli",
    "scaffold",
    "frontend"
  ],
  "author": "",
  "license": "ISC",
  "packageManager": "npm@10.9.3",
  "dependencies": {
    "axios": "^1.18.0",
    "colors": "^1.4.0",
    "commander": "^12.1.0",
    "consola": "^3.4.2",
    "dotenv": "^17.4.2",
    "ejs": "^6.0.1",
    "fs-extra": "^11.3.5",
    "inquirer": "8.2.6",
    "minimist": "^1.2.8",
    "root-check": "1.0.0",
    "semver": "^7.8.4"
  },
  "devDependencies": {
    "prettier": "^3.8.4"
  }
}
